# Overwatch Configuration
# Copy to .env.local and customize

# Optional password protection. Leave empty or remove for open access (localhost only).
# OVERWATCH_PASSWORD=your-secret-here

# Hermes home directory. Defaults to ~/.hermes if not set.
# HERMES_HOME=/home/user/.hermes

# Overwatch installation directory. Defaults to the current working directory (process.cwd()).
# Only needed if running the deploy API route from a non-standard location.
# OVERWATCH_DIR=/home/user/overwatch
